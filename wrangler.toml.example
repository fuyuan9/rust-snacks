name = "rust-snacks"
main = "apps/worker/src/index.ts"
compatibility_date = "2024-04-03"

[vars]
LLM_PROVIDER = "gemini"
LLM_MODEL = "gemini-3.5-flash"

[[kv_namespaces]]
binding = "KV"
id = "YOUR_KV_NAMESPACE_ID"

[[r2_buckets]]
binding = "BUCKET"
bucket_name = "rust-snacks-bucket"

[[d1_databases]]
binding = "DB"
database_name = "rust-snacks-db"
database_id = "YOUR_D1_DATABASE_ID"
migrations_dir = "packages/db/migrations"

[[queues.producers]]
queue = "rust-snacks-queue"
binding = "QUEUE"

[[queues.consumers]]
queue = "rust-snacks-queue"
max_batch_size = 1
max_batch_timeout = 5

[triggers]
crons = ["0 0 * * *"] # 毎日0時実行
